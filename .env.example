# ============================================================
# Server environment variables (set in Render dashboard)
# ============================================================

# Supabase (required)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...
SUPABASE_ANON_KEY=eyJhbGci...

# Retell AI (required)
RETELL_API_KEY=key_xxxx
RETELL_LLM_ID=llm_xxxx
RETELL_AGENT_ID=agent_xxxx

# Twilio (required for SMS)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google Calendar (required for booking)
GOOGLE_CALENDAR_ID=xxxx@group.calendar.google.com
# Either set GOOGLE_SERVICE_ACCOUNT_KEY_FILE (path to JSON)
# or GOOGLE_SERVICE_ACCOUNT_KEY (full JSON string — preferred for Render)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# App (required)
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# CRITICAL: Set these after first deploy
# WEBHOOK_BASE_URL must be your Render service URL, e.g.:
# https://voibixai-api.onrender.com
# After setting this, go to Admin → each client → Sync Agent
# to register tool URLs (check_availability, book_appointment, save_intake_data)
WEBHOOK_BASE_URL=https://your-render-url.onrender.com

# Your Vercel frontend URL — required for CORS
FRONTEND_URL=https://your-app.vercel.app

# ============================================================
# Client environment variables (set in Vercel dashboard)
# ============================================================

# VITE_API_URL=https://your-render-url.onrender.com/api
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGci...
